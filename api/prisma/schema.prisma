// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  avatarUrl  String?

  email      String   @unique
  role       UserRole @default(STUDENT)
  first_name String
  last_name  String
  bio        String?
  password   String

  teacher    Teacher?
  student    Student?

  phones     Phone[]
  courses Course[] @relation("AdminCourse")

  memberCourses  Course[] @relation("CourseMembers")
}

model Teacher {
  id     Int    @id
  salary Float

  user   User   @relation(fields: [id], references: [id])
}

model Student {
  id               Int    @id
  enrollmentNumber String @unique

  user             User   @relation(fields: [id], references: [id])
  frequencies       Frequency[]
}

model Phone {
  id      Int      @id @default(autoincrement())
  number  String

  user User @relation(fields:[userId], references: [id])
  userId  Int
}

model Course {
  id          Int      @id @default(autoincrement())
  imageUrl    String?

  name        String
  description String?
  is_active   Boolean  @default(true)

  start_date  DateTime
  end_date    DateTime

  userId   Int
  adminCourse     User  @relation("AdminCourse", fields: [userId], references: [id])

  members     User[]   @relation("CourseMembers")

  contents     Content[]

  attendances  Attendence[]

  timelines   Timeline[]
}

model Content {
  id       Int    @id @default(autoincrement())
  name     String
  description String?
  type     ContentType
  url      String

  courseId  Int
  course   Course  @relation(fields: [courseId], references: [id])

  timelines Timeline[]
}

model Attendence {
  id        Int      @id @default(autoincrement())
  date      DateTime

  courseId  Int
  course    Course   @relation(fields: [courseId], references: [id])

  frequencies Frequency[]

}

model Frequency {
  id        Int      @id @default(autoincrement())
  is_present Boolean

  attendenceId Int
  attendence   Attendence @relation(fields: [attendenceId], references: [id])

  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
}

model Timeline {
  id          Int      @id @default(autoincrement())

  is_done     Boolean  @default(false)
  date DateTime @db.Date
  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id])

  contentId   Int?
  content     Content? @relation(fields: [contentId], references: [id])
}


enum UserRole {
  ADMIN
  STUDENT
  TEACHER
}


enum ContentType {
  IMAGE
  VIDEO
  PDF
}
